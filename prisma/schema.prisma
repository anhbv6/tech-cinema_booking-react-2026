generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum MovieStatus {
  DRAFT
  NOW_SHOWING
  COMING_SOON
  ENDED
}

enum MovieSource {
  MANUAL
  TMDB
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(CUSTOMER)
  image     String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genre {
  id          String   @id @default(cuid())
  tmdbId      Int?     @unique
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movies MovieGenre[]

  @@index([isActive])
}

model Movie {
  id               String      @id @default(cuid())
  tmdbId           Int?        @unique
  source           MovieSource @default(MANUAL)

  title            String
  originalTitle    String?
  slug             String      @unique
  description      String?

  posterUrl        String?
  backdropUrl      String?
  trailerUrl       String?

  duration         Int?
  releaseDate      DateTime?
  originalLanguage String?
  voteAverage      Float?
  voteCount        Int?
  popularity       Float?

  status           MovieStatus @default(DRAFT)
  isActive         Boolean     @default(true)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  genres           MovieGenre[]

  @@index([status])
  @@index([isActive])
  @@index([source])
  @@index([releaseDate])
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Restrict)

  @@id([movieId, genreId])
  @@index([genreId])
}